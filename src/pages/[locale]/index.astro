---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import TechStack from '../../components/TechStack.astro';
import Projects from '../../components/Projects.astro';
import FrontierProjects from '../../components/FrontierProjects.astro';
import Algotrading from '../../components/Algotrading.astro';
import Communities from '../../components/Communities.astro';
import Contact from '../../components/Contact.astro';
import { locales, type Locale } from '../../i18n/config';

export const getStaticPaths = (() => {
  return locales.map((locale) => ({ params: { locale } }));
}) satisfies GetStaticPaths;

const { locale } = Astro.params as { locale: Locale };
---

<Layout locale={locale}>
  <Hero locale={locale} />
  <About locale={locale} />
  <Algotrading locale={locale} />
  <TechStack locale={locale} />
  <FrontierProjects locale={locale} />
  <Projects locale={locale} />
  <Communities locale={locale} />
  <Contact locale={locale} />
</Layout>
