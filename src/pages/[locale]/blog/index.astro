---
import type { GetStaticPaths } from 'astro';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import BlogCard from '../../../components/BlogCard.astro';
import TagList from '../../../components/TagList.astro';
import Search from '../../../components/Search.astro';
import { locales, type Locale } from '../../../i18n/config';
import { useTranslations } from '../../../i18n/ui';
import { getCollection } from 'astro:content';

export const getStaticPaths = (() => {
  return locales.map((locale) => ({ params: { locale } }));
}) satisfies GetStaticPaths;

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);

const allPosts = await getCollection('blog', ({ data, id }) => {
  return id.startsWith(`${locale}/`) && !data.draft;
});

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const allTags = posts.flatMap((post) => post.data.tags);

function getSlug(id: string): string {
  return id.replace(`${locale}/`, '').replace(/\.md$/, '');
}
---

<Layout
  title={`${t('blog.title')} — Eugen Soloviov`}
  description={t('blog.description')}
  locale={locale}
>
  <Nav locale={locale} />
  <main class="min-h-screen pt-24 pb-16">
    <div class="max-w-5xl mx-auto px-6">
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">{t('blog.title')}</h1>
        <p class="text-gray-400 text-lg">{t('blog.description')}</p>
      </header>

      <div class="mb-6">
        <Search placeholder={t('blog.search')} noResultsText={t('blog.noResults')} />
      </div>

      <div class="mb-8">
        <TagList tags={allTags} locale={locale} />
      </div>

      <div id="blog-search-container" data-no-results={t('blog.noResults')}>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <div data-blog-post data-title={post.data.title} data-description={post.data.description} data-slug={getSlug(post.id)} data-tags={post.data.tags.join(',')} data-pubdate={post.data.pubDate.toISOString()}>
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                heroImage={post.data.heroImage}
                slug={`/${locale}/blog/${getSlug(post.id)}/`}
                readMoreLabel={t('blog.readMore')}
              />
            </div>
          ))}
        </div>
        <p id="no-results" class="text-center text-gray-500 py-12 hidden">{t('blog.noResults')}</p>
      </div>
    </div>
  </main>
  <footer class="border-t border-white/5 py-8 text-center text-sm text-gray-400">
    <p class="font-mono text-xs tracking-wider">{t('footer.tagline')}</p>
  </footer>
</Layout>
