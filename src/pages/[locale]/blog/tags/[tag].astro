---
import type { GetStaticPaths } from 'astro';
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import BlogCard from '../../../../components/BlogCard.astro';
import TagList from '../../../../components/TagList.astro';
import { locales, type Locale } from '../../../../i18n/config';
import { useTranslations } from '../../../../i18n/ui';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async () => {
  const paths = [];
  for (const locale of locales) {
    const posts = await getCollection('blog', ({ id, data }) => {
      return id.startsWith(`${locale}/`) && !data.draft;
    });
    const tags = new Set<string>();
    posts.forEach((post) => post.data.tags.forEach((tag) => tags.add(tag)));

    for (const tag of tags) {
      paths.push({
        params: { locale, tag },
        props: { tag },
      });
    }
  }
  return paths;
}) satisfies GetStaticPaths;

const { locale } = Astro.params as { locale: Locale };
const { tag } = Astro.props;
const t = useTranslations(locale);

const allPosts = await getCollection('blog', ({ id, data }) => {
  return id.startsWith(`${locale}/`) && !data.draft;
});

const posts = allPosts
  .filter((post) => post.data.tags.includes(tag))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const allTags = allPosts.flatMap((post) => post.data.tags);

function getSlug(id: string): string {
  return id.replace(`${locale}/`, '').replace(/\.md$/, '');
}
---

<Layout
  title={`${t('blog.postsTagged')} "${tag}" — Eugen Soloviov`}
  description={t('blog.description')}
  locale={locale}
>
  <Nav locale={locale} />
  <main class="min-h-screen pt-24 pb-16">
    <div class="max-w-5xl mx-auto px-6">
      <header class="mb-10">
        <a href={`/${locale}/blog/`} class="text-sm text-gray-400 hover:text-violet-300 transition-colors">
          {t('blog.backToBlog')}
        </a>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3 mt-4">
          {t('blog.postsTagged')} <span class="text-violet-400">#{tag}</span>
        </h1>
        <p class="text-gray-500">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
      </header>

      <div class="mb-8">
        <TagList tags={allTags} locale={locale} activeTag={tag} />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            heroImage={post.data.heroImage}
            slug={`/${locale}/blog/${getSlug(post.id)}/`}
            readMoreLabel={t('blog.readMore')}
          />
        ))}
      </div>
    </div>
  </main>
  <footer class="border-t border-white/5 py-8 text-center text-sm text-gray-400">
    <p class="font-mono text-xs tracking-wider">{t('footer.tagline')}</p>
  </footer>
</Layout>
