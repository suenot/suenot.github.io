---
import type { GetStaticPaths } from 'astro';
import Layout from '../../../../layouts/Layout.astro';
import { locales, type Locale } from '../../../../i18n/config';
import { useTranslations } from '../../../../i18n/ui';
import { getCollection } from 'astro:content';

export const getStaticPaths = (() => {
  return locales.map((locale) => ({ params: { locale } }));
}) satisfies GetStaticPaths;

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);

const allPosts = await getCollection('blog', ({ id, data }) => {
  return id.startsWith(`${locale}/`) && !data.draft;
});

const tagCounts: Record<string, number> = {};
allPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<Layout
  title={`${t('blog.tags')} — Eugen Soloviov`}
  description={t('blog.description')}
  locale={locale}
>
  <div class="pt-24 pb-16">
    <div class="max-w-5xl mx-auto px-6">
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-display font-bold text-midnight mb-3 tracking-[-0.035em]">{t('blog.allTags')}</h1>
        <p class="text-body-sm text-smoke">{t('blog.description')}</p>
      </header>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {sortedTags.map(([tag, count]) => (
          <a
            href={`/${locale}/blog/tags/${tag}/`}
            class="group p-4 rounded-card border border-mist hover:border-silver transition-all"
          >
            <div class="text-midnight font-display font-semibold group-hover:text-carbon transition-colors tracking-[-0.035em]">#{tag}</div>
            <div class="text-caption text-smoke mt-1">{count} {count === 1 ? 'post' : 'posts'}</div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
