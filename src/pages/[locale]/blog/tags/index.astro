---
import type { GetStaticPaths } from 'astro';
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import { locales, type Locale } from '../../../../i18n/config';
import { useTranslations } from '../../../../i18n/ui';
import { getCollection } from 'astro:content';

export const getStaticPaths = (() => {
  return locales.map((locale) => ({ params: { locale } }));
}) satisfies GetStaticPaths;

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);

const allPosts = await getCollection('blog', ({ id, data }) => {
  return id.startsWith(`${locale}/`) && !data.draft;
});

const tagCounts: Record<string, number> = {};
allPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<Layout
  title={`${t('blog.tags')} — Eugen Soloviov`}
  description={t('blog.description')}
  locale={locale}
>
  <Nav locale={locale} />
  <main class="min-h-screen pt-24 pb-16">
    <div class="max-w-5xl mx-auto px-6">
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">{t('blog.allTags')}</h1>
        <p class="text-gray-400 text-lg">{t('blog.description')}</p>
      </header>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {sortedTags.map(([tag, count]) => (
          <a
            href={`/${locale}/blog/tags/${tag}/`}
            class="group p-4 rounded-xl bg-white/[0.03] border border-white/5 hover:border-violet-500/20 transition-all"
          >
            <div class="text-white font-medium group-hover:text-violet-300 transition-colors">#{tag}</div>
            <div class="text-sm text-gray-500 mt-1">{count} {count === 1 ? 'post' : 'posts'}</div>
          </a>
        ))}
      </div>
    </div>
  </main>
  <footer class="border-t border-white/5 py-8 text-center text-sm text-gray-400">
    <p class="font-mono text-xs tracking-wider">{t('footer.tagline')}</p>
  </footer>
</Layout>
