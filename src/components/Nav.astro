---
import LanguageSelector from './LanguageSelector.astro';
import { type Locale } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = useTranslations(locale);

const links = [
  { href: `/${locale}/#about`, label: t('nav.about') },
  { href: `/${locale}/#tech`, label: t('nav.tech') },
  { href: `/${locale}/#projects`, label: t('nav.projects') },
  { href: `/${locale}/#contact`, label: t('nav.contact') },
  { href: `/${locale}/blog/`, label: t('nav.blog') },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-canvas/90 backdrop-blur-sm border-b border-mist">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={`/${locale}/`} class="font-display text-midnight font-bold text-body tracking-[-0.035em]">
      suenot<span class="text-smoke">.com</span>
    </a>
    <ul class="hidden sm:flex items-center gap-6">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-body-sm font-display font-semibold text-midnight hover:text-carbon transition-colors duration-200 tracking-[-0.035em]"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="flex items-center gap-4">
      <LanguageSelector currentLocale={locale} />
      <a
        href="https://github.com/suenot"
        target="_blank"
        rel="noopener noreferrer"
        class="text-body-sm text-silver hover:text-midnight transition-colors font-sans hidden sm:inline"
      >
        github →
      </a>
    </div>
  </div>
</nav>
