---
import { defaultLocale, type Locale } from '../i18n/config';
import { getHome } from '../i18n/home';

interface Props {
  locale?: Locale;
}
const { locale = defaultLocale } = Astro.props;
const t = getHome(locale).communities;

interface Community {
  key: keyof typeof t.items;
  url: string;
  handle: string;
  platform: string;
  color: string;
  icon: string;
}

const telegramIcon = `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>`;

const communities: Community[] = [
  {
    key: 'klavaorgwork',
    url: 'https://t.me/klavaorgwork',
    handle: '@klavaorgwork',
    platform: 'Telegram',
    color: '#2CA5E0',
    icon: telegramIcon,
  },
];
---

<section id="communities" class="py-24">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-violet-400 font-mono text-sm mb-3">{t.eyebrow}</p>
    <h2 class="text-3xl font-bold text-white mb-12">{t.heading}</h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {communities.map((c) => (
        <a
          href={c.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-4 p-5 rounded-xl bg-white/[0.03] border border-white/5 hover:border-white/10 hover:bg-white/[0.06] transition-all duration-200"
        >
          <span class="flex-shrink-0 opacity-70 group-hover:opacity-100 transition-opacity mt-0.5" style={`color: ${c.color}`} set:html={c.icon} />
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-white text-sm font-medium">{t.items[c.key].name}</span>
              <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-gray-400 font-mono">{c.platform}</span>
            </div>
            <div class="text-gray-400 text-xs font-mono mb-2">{c.handle}</div>
            <p class="text-gray-400 text-xs leading-relaxed">{t.items[c.key].desc}</p>
          </div>
          <span class="text-gray-500 group-hover:text-gray-300 transition-colors text-sm">→</span>
        </a>
      ))}
    </div>
  </div>
</section>
