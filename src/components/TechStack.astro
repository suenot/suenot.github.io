function getIcon(name: string): { path: string; hex: string } | null {
  const key = iconMap[name];
  if (!key) return null;
  const icon = (si as Record<string, { path: string; hex: string } | undefined>)[key];
  return icon ?? null;
}

// WCAG 2.1 relative luminance (proper sRGB linearization)
function srgbLuminance(hex: string): number {
  const r = parseInt(hex.slice(1, 3), 16) / 255;
  const g = parseInt(hex.slice(3, 5), 16) / 255;
  const b = parseInt(hex.slice(5, 7), 16) / 255;
  const lin = (c: number) => c <= 0.04045 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
  return 0.2126 * lin(r) + 0.7152 * lin(g) + 0.0722 * lin(b);
}

// Lighten hex color to ensure WCAG AA contrast (4.5:1) on #0A0A14 background
const BG_LUM = srgbLuminance('#0A0A14'); // ~0.003
function lightenForContrast(hex: string): string {
  const lum = srgbLuminance(hex);
  const ratio = (lum + 0.05) / (BG_LUM + 0.05);
  if (ratio >= 7) return hex;
  // Iteratively mix with white until contrast >= 4.5
  let factor = 0;
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  for (let i = 1; i <= 20; i++) {
    factor = i * 0.05;
    const nr = Math.round(r + (255 - r) * factor);
    const ng = Math.round(g + (255 - g) * factor);
    const nb = Math.round(b + (255 - b) * factor);
    const newHex = `#${nr.toString(16).padStart(2, '0')}${ng.toString(16).padStart(2, '0')}${nb.toString(16).padStart(2, '0')}`;
    const newLum = srgbLuminance(newHex);
    if ((newLum + 0.05) / (BG_LUM + 0.05) >= 7) {
      return newHex;
    }
  }
  return '#ffffff';
}

