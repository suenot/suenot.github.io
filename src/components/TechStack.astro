---

<section id="tech" class="py-24">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-violet-400 font-mono text-sm mb-3">02. tech stack</p>
    <h2 class="text-3xl font-bold text-white mb-12">Technologies I use</h2>

    <div class="space-y-10">
      {techCategories.map((category) => (
        <div>
          <h3 class="text-xs font-mono text-gray-400 uppercase tracking-widest mb-4">
            {category.name}
          </h3>
          <div class="flex flex-wrap gap-2">
            {category.items.map((tech) => {
              const icon = getIcon(tech.name);
              const textColor = lightenForContrast(tech.color);
              return (
                <span
                  class={`inline-flex items-center gap-2 px-3 py-1.5 rounded-md border transition-all duration-200 hover:scale-105 cursor-default ${category.primary ? 'text-sm font-semibold' : 'text-xs font-medium'}`}
                  style={`background-color: ${tech.color}18; border-color: ${tech.color}35; color: ${textColor};`}
                >
                  {icon ? (
                    <svg
                      role="img"
                      viewBox="0 0 24 24"
                      class="w-3.5 h-3.5 flex-shrink-0"
                      fill="currentColor"
                      aria-label={tech.name}
                    >
                      <path d={icon.path} />
                    </svg>
                  ) : (
                    <span
                      class="w-2 h-2 rounded-full flex-shrink-0"
                      style={`background-color: ${tech.color};`}
                    />
                  )}
                  {tech.name}
                </span>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
