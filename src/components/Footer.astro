---
import { defaultLocale, type Locale } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale?: Locale;
}
const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
const rssHref = locale === defaultLocale ? '/blog/feed.xml' : `/${locale}/blog/feed.xml`;

const navCol = [
  { label: t('nav.about'), href: '#about' },
  { label: t('nav.projects'), href: '#projects' },
  { label: t('nav.frontier'), href: '#frontier' },
  { label: t('nav.tech'), href: '#tech' },
  { label: t('nav.algotrading'), href: '#algotrading' },
  { label: t('nav.blog'), href: locale === defaultLocale ? '/blog' : `/${locale}/blog` },
];

const connectCol = [
  { label: 'GitHub', href: 'https://github.com/suenot' },
  { label: 'Telegram', href: 'https://t.me/suenot' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/suenot/' },
  { label: 'X / Twitter', href: 'https://x.com/suenot' },
  { label: 'Email', href: 'mailto:suenot@gmail.com' },
];

const workCol = [
  { label: 'Marketmaker.cc', href: 'https://marketmaker.cc', sub: 'CEO' },
  { label: 'Cmdop.com', href: 'https://cmdop.com', sub: 'CTO' },
  { label: 'Habr', href: 'https://habr.com/ru/users/suenot/', sub: t('footer.work_articles') },
  { label: 'Stack Overflow', href: 'https://stackoverflow.com/users/937966/eugen-soloviov', sub: t('footer.work_qa') },
];
---

<footer class="relative overflow-hidden bg-[#06060E] border-t border-white/5">
  <!-- Top hairline gradient -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-violet-500/40 to-transparent"></div>

  <!-- Ambient blobs (CSS-only, very cheap) -->
  <div class="pointer-events-none absolute -top-32 -left-32 h-96 w-96 rounded-full bg-violet-600/10 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-40 -right-24 h-[28rem] w-[28rem] rounded-full bg-blue-600/10 blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-6 pt-20 pb-8">

    <!-- CTA row -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-10 pb-16 border-b border-white/5">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-500/10 border border-green-500/20 text-green-300 text-xs font-mono mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
          {t('footer.status_available')}
        </div>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-[1.05] max-w-2xl">
          {t('footer.cta_heading')}<br />
          <span class="bg-gradient-to-r from-fuchsia-300 via-violet-300 to-cyan-300 bg-clip-text text-transparent">
            {t('footer.cta_heading_accent')}
          </span>
        </h2>
      </div>

      <a
        href="mailto:suenot@gmail.com"
        class="footer-cta group inline-flex items-center gap-3 self-start lg:self-end px-6 py-4 rounded-full bg-white text-[#06060E] font-medium text-base hover:bg-fuchsia-200 transition-colors duration-200 whitespace-nowrap"
      >
        <span>suenot@gmail.com</span>
        <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-[#06060E] text-white group-hover:translate-x-1 transition-transform">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
    </div>

    <!-- Columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 py-16">
      <!-- Sitemap -->
      <div>
        <div class="text-xs font-mono uppercase tracking-widest text-gray-500 mb-5">
          {t('footer.col_sitemap')}
        </div>
        <ul class="space-y-3">
          {navCol.map((l) => (
            <li>
              <a href={l.href} class="footer-link text-gray-300 hover:text-white text-sm">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <div class="text-xs font-mono uppercase tracking-widest text-gray-500 mb-5">
          {t('footer.col_connect')}
        </div>
        <ul class="space-y-3">
          {connectCol.map((l) => (
            <li>
              <a
                href={l.href}
                target={l.href.startsWith('http') ? '_blank' : undefined}
                rel={l.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="footer-link text-gray-300 hover:text-white text-sm"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Work -->
      <div>
        <div class="text-xs font-mono uppercase tracking-widest text-gray-500 mb-5">
          {t('footer.col_work')}
        </div>
        <ul class="space-y-3">
          {workCol.map((l) => (
            <li>
              <a
                href={l.href}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-link group/work text-gray-300 hover:text-white text-sm flex items-baseline gap-2"
              >
                <span>{l.label}</span>
                <span class="text-[10px] font-mono uppercase tracking-wider text-gray-600 group-hover/work:text-violet-300">
                  {l.sub}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Locale / RSS card -->
      <div>
        <div class="text-xs font-mono uppercase tracking-widest text-gray-500 mb-5">
          {t('footer.col_more')}
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-5 hover:border-violet-500/30 hover:bg-white/[0.04] transition-colors">
          <div class="flex items-center gap-2 text-violet-300 text-xs font-mono mb-2">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36ZM4 4.44A19.56 19.56 0 0 1 23.56 24h-2.83A16.73 16.73 0 0 0 4 7.27V4.44Zm0 5.66A13.93 13.93 0 0 1 17.9 24h-2.83A11.1 11.1 0 0 0 4 12.93V10.1Z"/></svg>
            RSS
          </div>
          <a href={rssHref} class="block text-white text-sm font-medium mb-1 hover:underline">
            {t('footer.rss_title')}
          </a>
          <p class="text-gray-500 text-xs leading-relaxed">
            {t('footer.rss_sub')}
          </p>
        </div>
      </div>
    </div>

    <!-- Massive wordmark -->
    <div class="relative -mx-6 px-6 py-2 select-none" aria-hidden="true">
      <div
        id="footer-wordmark"
        class="footer-wordmark font-bold tracking-tighter text-transparent leading-[0.85] text-center"
        style="font-size: clamp(4rem, 18vw, 16rem);"
      >
        SUENOT
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="mt-8 pt-6 border-t border-white/5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-xs text-gray-500 font-mono">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <span>© {year} Eugen Soloviov</span>
        <span class="hidden sm:inline opacity-30">·</span>
        <span class="opacity-80">{t('footer.tagline')}</span>
      </div>
      <div class="flex items-center gap-4">
        <span class="opacity-60">{t('footer.built_with')} Astro + Tailwind</span>
        <button
          type="button"
          id="footer-top"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-white/10 hover:border-white/30 hover:text-white transition-colors"
          aria-label={t('footer.scroll_top')}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3 h-3"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
          <span>{t('footer.scroll_top')}</span>
        </button>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Animated underline reveal on hover */
  .footer-link {
    position: relative;
    display: inline-block;
    transition: color 0.2s;
  }
  .footer-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    height: 1px;
    width: 100%;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.35s cubic-bezier(0.65, 0, 0.35, 1);
  }
  .footer-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Wordmark: gradient stroke effect with cursor-following highlight */
  .footer-wordmark {
    background-image:
      radial-gradient(
        circle 18rem at var(--mx, 50%) var(--my, 50%),
        rgba(216, 180, 254, 0.95) 0%,
        rgba(167, 139, 250, 0.55) 35%,
        rgba(255, 255, 255, 0.06) 70%
      );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.08);
  }

  /* Magnetic CTA: subtle scale on hover */
  .footer-cta {
    transition: transform 0.25s ease, background-color 0.2s ease;
  }
  .footer-cta:hover {
    transform: translateY(-2px);
  }
</style>

<script>
  // Cursor-tracked highlight on the wordmark + smooth scroll-to-top.
  const wm = document.getElementById('footer-wordmark') as HTMLElement | null;
  if (wm && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    wm.addEventListener('pointermove', (e) => {
      const r = wm.getBoundingClientRect();
      wm.style.setProperty('--mx', `${e.clientX - r.left}px`);
      wm.style.setProperty('--my', `${e.clientY - r.top}px`);
    });
  }

  document.getElementById('footer-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
