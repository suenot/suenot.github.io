---
import { defaultLocale, type Locale } from '../i18n/config';
import { getHome } from '../i18n/home';

interface Props {
  locale?: Locale;
}
const { locale = defaultLocale } = Astro.props;
const t = getHome(locale).about;
---

<section id="about" class="py-24 bg-[#0D0D1A]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <p class="text-violet-400 font-mono text-sm mb-3">{t.eyebrow}</p>
        <h2 class="text-3xl font-bold text-white mb-6">{t.heading}</h2>
        <div class="space-y-4 text-gray-400 leading-relaxed">
          <p>
            {t.p1_prefix}<span class="text-white font-medium">Marketmaker.cc</span>{t.p1_marketmaker_suffix}<span class="text-white font-medium">Cmdop.com</span>{t.p1_cmdop_suffix}
          </p>
          <p>
            {t.p2_prefix}<span class="text-white font-medium">{t.p2_year}</span>{t.p2_suffix}
          </p>
          <p>
            {t.p3_prefix}<span class="text-white font-medium">{t.p3_langs}</span>{t.p3_suffix}
          </p>
        </div>
      </div>

      <div class="space-y-4">
        <p class="text-violet-400 font-mono text-sm mb-3">{t.focus_eyebrow}</p>
        {t.focus.map((item) => (
          <div class="flex gap-4 p-4 rounded-lg bg-white/[0.03] border border-white/5 hover:border-violet-500/20 transition-colors">
            <span class="text-2xl">{item.icon}</span>
            <div>
              <h3 class="text-white font-medium text-sm">{item.title}</h3>
              <p class="text-gray-400 text-sm mt-1">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
