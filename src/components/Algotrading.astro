---
import { defaultLocale, type Locale } from '../i18n/config';
import { getHome } from '../i18n/home';

interface Props {
  locale?: Locale;
}
const { locale = defaultLocale } = Astro.props;
const t = getHome(locale).algotrading;

// Tag chips per section, keyed by section index (same order as t.sections)
const sectionTags: { name: string; classes: string }[][] = [
  // 0 Backtesting
  [
    { name: 'Python', classes: 'border-violet-500/20 bg-violet-500/5 text-violet-300' },
    { name: 'Zig', classes: 'border-blue-500/20 bg-blue-500/5 text-blue-300' },
    { name: 'Optuna', classes: 'border-orange-500/20 bg-orange-500/5 text-orange-300' },
  ],
  // 1 Listings
  [
    { name: 'Rust', classes: 'border-orange-500/20 bg-orange-500/5 text-orange-300' },
    { name: 'Zig', classes: 'border-blue-500/20 bg-blue-500/5 text-blue-300' },
    { name: 'gRPC', classes: 'border-green-500/20 bg-green-500/5 text-green-300' },
  ],
  // 2 HFT
  [
    { name: 'Golang', classes: 'border-blue-500/20 bg-blue-500/5 text-blue-300' },
    { name: 'Rust', classes: 'border-orange-500/20 bg-orange-500/5 text-orange-300' },
    { name: 'C++', classes: 'border-red-500/20 bg-red-500/5 text-red-300' },
  ],
  // 3 Arbitrage Systems
  [
    { name: 'Go', classes: 'border-blue-500/20 bg-blue-500/5 text-blue-300' },
    { name: 'Python', classes: 'border-violet-500/20 bg-violet-500/5 text-violet-300' },
    { name: 'Next.js', classes: 'border-green-500/20 bg-green-500/5 text-green-300' },
  ],
  // 4 Portfolio Optimization
  [
    { name: 'Python', classes: 'border-violet-500/20 bg-violet-500/5 text-violet-300' },
    { name: 'SciPy', classes: 'border-orange-500/20 bg-orange-500/5 text-orange-300' },
    { name: 'Math', classes: 'border-gray-500/20 bg-gray-500/5 text-gray-300' },
  ],
];
---

<section id="algotrading" class="py-24 bg-[#0A0A14]">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-violet-400 font-mono text-sm mb-3">{t.eyebrow}</p>
    <h2 class="text-3xl font-bold text-white mb-4">{t.heading}</h2>
    <p class="text-gray-400 mb-12 max-w-xl">
      {t.intro}
    </p>

    <div class="space-y-16">
      {t.sections.map((section, i) => (
        <div class="grid md:grid-cols-[1fr_2fr] gap-8 items-start">
          <div class="space-y-4">
            <h3 class="text-xl font-bold text-white">{section.title}</h3>
            <p class="text-violet-400 font-mono text-xs uppercase tracking-wider">{section.subtitle}</p>
            <div class="flex flex-wrap gap-2">
              {(sectionTags[i] ?? []).map((tag) => (
                <span class={`text-[10px] px-2 py-0.5 rounded border font-mono ${tag.classes}`}>{tag.name}</span>
              ))}
            </div>
          </div>
          <div class="bg-white/[0.02] border border-white/5 p-6 rounded-2xl">
            <ul class="space-y-4 text-gray-400 text-sm leading-relaxed">
              {section.bullets.map((bullet) => (
                <li class="flex gap-3">
                  <span class="text-violet-500 mt-1">▹</span>
                  <span set:html={bullet} />
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
