---
import { locales, localeNames, type Locale } from '../i18n/config';

interface Props {
  currentLocale: Locale;
  slug: string;
  availableLocales: Locale[];
  label: string;
}

const { currentLocale, slug, availableLocales, label } = Astro.props;

const otherLocales = availableLocales.filter((l) => l !== currentLocale);
---

{otherLocales.length > 0 && (
  <div class="flex items-center gap-3 text-sm flex-wrap">
    <span class="text-gray-500">{label}:</span>
    {otherLocales.map((loc) => (
      <a
        href={`/${loc}/blog/${slug}/`}
        class="px-2 py-1 rounded bg-white/[0.03] border border-white/5 text-gray-400 hover:text-violet-300 hover:border-violet-500/20 transition-colors"
      >
        {localeNames[loc]}
      </a>
    ))}
  </div>
)}
