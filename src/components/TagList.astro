---
import { type Locale } from '../i18n/config';
import { getLocalePrefix } from '../i18n/utils';

interface Props {
  tags: string[];
  locale: Locale;
  activeTag?: string;
}

const { tags, locale, activeTag } = Astro.props;
const prefix = getLocalePrefix(locale);

const uniqueTags = [...new Set(tags)].sort();
---

<div class="flex flex-wrap gap-2">
  <a
    href={`${prefix}/blog/`}
    class:list={[
      'px-3 py-1.5 text-sm rounded-full border transition-colors duration-200',
      !activeTag
        ? 'bg-violet-500/20 text-violet-300 border-violet-500/30'
        : 'bg-white/[0.03] text-gray-400 border-white/5 hover:border-violet-500/20 hover:text-white',
    ]}
  >
    All
  </a>
  {uniqueTags.map((tag) => (
    <a
      href={`${prefix}/blog/tags/${tag}/`}
      class:list={[
        'px-3 py-1.5 text-sm rounded-full border transition-colors duration-200',
        activeTag === tag
          ? 'bg-violet-500/20 text-violet-300 border-violet-500/30'
          : 'bg-white/[0.03] text-gray-400 border-white/5 hover:border-violet-500/20 hover:text-white',
      ]}
    >
      {tag}
    </a>
  ))}
</div>
