---
interface Props {
  tags: string[];
  locale: string;
  activeTag?: string;
}

const { tags, locale, activeTag } = Astro.props;

const uniqueTags = [...new Set(tags)].sort();
---

<div class="flex flex-wrap gap-2">
  <a
    href={`/${locale}/blog/`}
    class:list={[
      'px-3 py-1.5 text-sm rounded-btn border transition-colors duration-200',
      !activeTag
        ? 'bg-accent-yellow text-midnight border-mist font-semibold'
        : 'bg-canvas text-silver border-mist hover:border-silver hover:text-midnight',
    ]}
  >
    All
  </a>
  {uniqueTags.map((tag) => (
    <a
      href={`/${locale}/blog/tags/${tag}/`}
      class:list={[
        'px-3 py-1.5 text-sm rounded-btn border transition-colors duration-200',
        activeTag === tag
          ? 'bg-accent-yellow text-midnight border-mist font-semibold'
          : 'bg-canvas text-silver border-mist hover:border-silver hover:text-midnight',
      ]}
    >
      {tag}
    </a>
  ))}
</div>
