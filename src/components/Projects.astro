---

<section id="projects" class="py-24 bg-[#0D0D1A]">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-violet-400 font-mono text-sm mb-3">03. projects</p>
    <h2 class="text-3xl font-bold text-white mb-4">What I'm building</h2>
    <p class="text-gray-500 mb-12 max-w-xl">
      Across Reforms.ai products, open-source tools, and HFT infrastructure research.
    </p>

    <div class="space-y-12">
      {projects.map((group) => (
        <div>
          <h3 class="text-xs font-mono text-gray-600 uppercase tracking-widest mb-6 pb-3 border-b border-white/5">
            {group.category}
          </h3>
          <div class="grid sm:grid-cols-2 gap-4">
            {group.items.map((project) => (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group block p-5 rounded-xl bg-white/[0.03] border border-white/5 hover:border-violet-500/30 hover:bg-violet-500/5 transition-all duration-200"
              >
                <div class="flex items-start justify-between gap-3 mb-3">
                  <div class="flex items-center gap-2">
                    <h4 class="text-white font-semibold group-hover:text-violet-300 transition-colors">
                      {project.name}
                    </h4>
                    {project.private ? (
                      <svg class="w-3.5 h-3.5 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                      </svg>
                    ) : (
                      <svg class="w-3.5 h-3.5 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z" />
                        <line x1="6" y1="1" x2="6" y2="4" />
                        <line x1="10" y1="1" x2="10" y2="4" />
                        <line x1="14" y1="1" x2="14" y2="4" />
                      </svg>
                    )}
                  </div>
                  <span class={`flex-shrink-0 text-xs px-2 py-0.5 rounded-full border ${statusStyles[project.status]}`}>
                    {statusLabels[project.status]}
                  </span>
                </div>
                <p class="text-gray-500 text-sm leading-relaxed mb-4">{project.desc}</p>
                <div class="flex flex-wrap gap-1.5">
                  {project.tags.map((tag) => (
                    <span class="text-xs px-2 py-0.5 rounded bg-white/5 text-gray-500 font-mono">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
