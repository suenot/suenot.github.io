const statusStyles: Record<StatusKey, string> = {
  active: 'bg-green-500/10 text-green-400 border-green-500/20',
  wip: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
  concept: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  paused: 'bg-gray-500/10 text-gray-400 border-gray-500/20',
  left: 'bg-orange-500/10 text-orange-400 border-orange-500/20',
  rip: 'bg-gray-700/10 text-gray-400 border-gray-700/20',
