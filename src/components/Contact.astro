---

<section id="contact" class="py-24">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-violet-400 font-mono text-sm mb-3">04. contact</p>
    <h2 class="text-3xl font-bold text-white mb-4">Get in touch</h2>
    <p class="text-gray-500 mb-12 max-w-xl">
      Open to interesting projects, collaboration, or just a chat about trading, HFT, or AI tooling.
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {links.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 p-4 rounded-xl bg-white/[0.03] border border-white/5 hover:border-white/10 hover:bg-white/[0.06] transition-all duration-200"
        >
          <span class="flex-shrink-0 opacity-70 group-hover:opacity-100 transition-opacity" style={`color: ${link.color}`} set:html={link.icon} />
          <div>
            <div class="text-white text-sm font-medium">{link.name}</div>
            <div class="text-gray-600 text-xs font-mono mt-0.5">{link.handle}</div>
          </div>
          <span class="ml-auto text-gray-700 group-hover:text-gray-400 transition-colors text-sm">→</span>
        </a>
      ))}
    </div>
  </div>
</section>
