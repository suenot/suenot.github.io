---
// Fetch GitHub stats at build time
let repoCount = '450+';
let starCount = '650+';

try {
  const userRes = await fetch('https://api.github.com/users/suenot', {
    headers: { 'Accept': 'application/vnd.github.v3+json' }
  });
  const userData = await userRes.json();
  repoCount = String(userData.public_repos ?? '450+');

  // Paginate through all repos to sum stars
  let totalStars = 0;
  let page = 1;
  while (true) {
    const reposRes = await fetch(
      `https://api.github.com/users/suenot/repos?per_page=100&page=${page}&type=owner`,
      { headers: { 'Accept': 'application/vnd.github.v3+json' } }
    );
    const repos: { stargazers_count: number; fork: boolean }[] = await reposRes.json();
    if (!Array.isArray(repos) || repos.length === 0) break;
    totalStars += repos.filter(r => !r.fork).reduce((s, r) => s + r.stargazers_count, 0);
    if (repos.length < 100) break;
    page++;
  }
  starCount = totalStars > 0 ? String(totalStars) : '650+';
} catch {
  // fallback to hardcoded values
}
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <div class="relative max-w-5xl mx-auto px-6 text-center">
    <!-- Status badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-btn bg-accent-yellow border border-mist text-carbon text-caption font-display font-semibold mb-8 tracking-[-0.035em]">
      <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
      Co-founder & CTO @ Reforms.ai
    </div>

    <h1 class="text-display font-display font-bold tracking-[-3.01px] mb-6 text-midnight leading-[0.95]">
      Eugen
      <br />
      Soloviov
    </h1>

    <p class="text-subheading text-smoke font-display font-semibold max-w-2xl mx-auto mb-4 tracking-[-0.035em]">
      Fullstack · DevOps · Algotrading Developer
    </p>

    <p class="text-body-sm text-silver max-w-xl mx-auto mb-10 leading-relaxed">
      Building algorithmic trading platforms, HFT infrastructure,
      and AI-powered developer tools. Trading since 2011.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="#projects"
        class="px-6 py-3 rounded-btn bg-midnight text-canvas font-display font-semibold text-body-sm transition-all duration-200 hover:bg-carbon tracking-[-0.035em]"
      >
        View Projects
      </a>
      <a
        href="#contact"
        class="px-6 py-3 rounded-btn border border-mist text-silver hover:text-midnight hover:border-midnight font-display font-semibold text-body-sm transition-all duration-200 tracking-[-0.035em]"
      >
        Get in Touch
      </a>
    </div>

    <!-- Stats row -->
    <div class="mt-20 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-2xl mx-auto">
      {[
        { value: '15+', label: 'Years in dev' },
        { value: '15+', label: 'Years trading' },
        { value: starCount, label: 'GitHub stars' },
        { value: repoCount, label: 'GitHub repos' },
      ].map((stat) => (
        <div class="text-center">
          <div class="text-heading font-display font-bold text-midnight tracking-[-0.035em]">{stat.value}</div>
          <div class="text-caption text-smoke mt-1 font-display font-semibold uppercase tracking-wider">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
