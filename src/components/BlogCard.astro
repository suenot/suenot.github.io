---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  heroImage?: string;
  slug: string;
  readMoreLabel: string;
}

const { title, description, pubDate, tags, heroImage, slug, readMoreLabel } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group rounded-card border border-mist overflow-hidden hover:border-silver transition-all duration-300">
  {heroImage && (
    <div class="aspect-video bg-gray-50 overflow-hidden">
      <img src={heroImage} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
    </div>
  )}
  <div class="p-5">
    <time datetime={pubDate.toISOString()} class="text-caption text-smoke font-display font-semibold uppercase">{formattedDate}</time>
    <h3 class="text-body font-display font-bold text-midnight mt-2 mb-2 group-hover:text-carbon transition-colors tracking-[-0.035em]">
      <a href={slug} class="hover:underline">{title}</a>
    </h3>
    <p class="text-body-sm text-smoke leading-relaxed mb-4">{description}</p>
    <div class="flex flex-wrap gap-1.5 mb-3">
      {tags.slice(0, 3).map((tag) => (
        <span class="px-2 py-0.5 text-xs rounded-btn bg-accent-yellow text-carbon border border-mist">{tag}</span>
      ))}
    </div>
    <a href={slug} class="inline-flex items-center gap-1.5 text-caption font-display font-semibold text-silver group-hover:text-midnight transition-colors duration-200 uppercase tracking-wider">
      <span>{readMoreLabel}</span>
      <svg class="w-3.5 h-3.5 transform transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</article>
