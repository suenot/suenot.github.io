---
interface FrontierProject {
  name: string;
  role: string;
  desc: string;
  tags: string[];
  url: string;
}

const frontier: FrontierProject[] = [
  {
    name: 'Marketmaker.cc',
    role: 'Co-founder & CEO',
    desc: 'Algorithmic trading platform & scalping terminal. 60+ crypto exchanges, real-time data, backtesting engine.',
    tags: ['Go', 'TypeScript', 'QuestDB', 'DuckDB'],
    url: 'https://marketmaker.cc',
  },
  {
    name: 'Cmdop.com',
    role: 'Co-founder & CTO',
    desc: 'Remote server management via AI agents. Telegram/Discord/Slack bots, browser automation, skills marketplace.',
    tags: ['TypeScript', 'AI Agents'],
    url: 'https://cmdop.com',
  },
];
---

<section id="frontier" class="py-24">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-violet-400 font-mono text-sm mb-3">04. frontier projects</p>
    <h2 class="text-3xl font-bold text-white mb-4">Where I'm leading</h2>
    <p class="text-gray-400 mb-12 max-w-xl">
      Two companies where I hold founding leadership roles.
    </p>

    <div class="grid sm:grid-cols-2 gap-6">
      {frontier.map((project) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative block p-7 rounded-2xl bg-gradient-to-br from-violet-500/10 via-white/[0.03] to-blue-500/5 border border-violet-500/20 hover:border-violet-400/50 hover:from-violet-500/15 transition-all duration-300 overflow-hidden"
        >
          <div class="absolute -top-12 -right-12 w-40 h-40 rounded-full bg-violet-500/10 blur-3xl group-hover:bg-violet-500/20 transition-all duration-500"></div>

          <div class="relative">
            <div class="flex items-start justify-between gap-3 mb-4">
              <h3 class="text-2xl font-bold text-white group-hover:text-violet-200 transition-colors">
                {project.name}
              </h3>
              <span class="flex-shrink-0 text-xs px-2.5 py-1 rounded-full border bg-green-500/10 text-green-400 border-green-500/20 font-mono">
                active
              </span>
            </div>

            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-violet-500/15 border border-violet-500/30 text-violet-200 text-xs font-mono mb-5">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
              {project.role}
            </div>

            <p class="text-gray-300 text-sm leading-relaxed mb-5">{project.desc}</p>

            <div class="flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded bg-white/5 text-gray-300 font-mono border border-white/5">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
