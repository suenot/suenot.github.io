---
import Analytics from '@vercel/analytics/astro';
import SEO from '../components/SEO.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { type Locale, isRtl, defaultLocale } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  modifiedDate?: Date;
  tags?: string[];
}

const {
  title = 'Eugen Soloviov — Fullstack & Algotrading Developer',
  description = 'Co-founder & CEO of Marketmaker.cc | CTO of Cmdop.com. Building algorithmic trading platforms, HFT infrastructure, and AI-powered tools.',
  locale = defaultLocale,
  ogImage,
  type = 'website',
  publishedDate,
  modifiedDate,
  tags,
} = Astro.props;

const dir = isRtl(locale) ? 'rtl' : 'ltr';
useTranslations(locale);
const rssHref = locale === defaultLocale ? '/blog/feed.xml' : `/${locale}/blog/feed.xml`;
---

<!doctype html>
<html lang={locale} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`Eugen Soloviov — Blog (${locale})`} href={rssHref} />
    <title>{title}</title>
    <SEO
      title={title}
      description={description}
      locale={locale}
      ogImage={ogImage}
      type={type}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate}
      tags={tags}
    />
  </head>
  <body class="bg-[#0A0A14] text-gray-100 font-sans antialiased flex flex-col min-h-screen">
    <Nav locale={locale} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    <Analytics />
  </body>
</html>
