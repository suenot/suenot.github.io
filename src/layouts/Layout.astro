---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Eugen Soloviov — Fullstack & Algotrading Developer',
  description = 'Co-founder & CTO of Reforms.ai. Building algorithmic trading platforms, HFT infrastructure, and AI-powered tools.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <title>{title}</title>
  </head>
  <body class="bg-[#0A0A14] text-gray-100 font-sans antialiased">
    <slot />
  </body>
</html>
