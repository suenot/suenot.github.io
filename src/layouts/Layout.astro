---
import SEO from '../components/SEO.astro';
import Nav from '../components/Nav.astro';
import { type Locale, isRtl, defaultLocale } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  modifiedDate?: Date;
  tags?: string[];
}

const {
  title = 'Eugen Soloviov — Fullstack & Algotrading Developer',
  description = 'Co-founder & CTO of Reforms.ai. Building algorithmic trading platforms, HFT infrastructure, and AI-powered tools.',
  locale = defaultLocale,
  ogImage,
  type = 'website',
  publishedDate,
  modifiedDate,
  tags,
} = Astro.props;

const dir = isRtl(locale) ? 'rtl' : 'ltr';
const t = useTranslations(locale);
---

<!doctype html>
<html lang={locale} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <SEO
      title={title}
      description={description}
      locale={locale}
      ogImage={ogImage}
      type={type}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate}
      tags={tags}
    />
  </head>
  <body class="bg-canvas text-carbon font-sans antialiased flex flex-col min-h-screen">
    <Nav locale={locale} />
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-mist py-8 text-center text-body-sm text-smoke">
      <p class="font-display text-caption tracking-wider font-semibold uppercase">{t('footer.tagline')}</p>
    </footer>
  </body>
</html>
